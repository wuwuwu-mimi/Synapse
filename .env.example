# ------------------------------------------------------------------------------
# Synapse runtime
# ------------------------------------------------------------------------------
# Backend URL used by Electron renderer. In normal local development you can keep
# the default value because the Python service listens on 127.0.0.1:8000.
RAG_BACKEND_URL=http://127.0.0.1:8000

# Whether Electron should auto-start the FastAPI service.
RAG_BACKEND_AUTOSTART=true

# Python executable used to start the backend.
# On Windows, Synapse will prefer pythonw.exe automatically when available so the
# extra console window does not stay open.
PYTHON_EXECUTABLE=python

# ------------------------------------------------------------------------------
# Infrastructure
# ------------------------------------------------------------------------------
# Redis is used to persist summary, extracted facts, and lightweight session
# state across backend restarts.
REDIS_URL=redis://127.0.0.1:6379/0

# PostgreSQL / pgvector connection string used by RetrievalService.
POSTGRES_DSN=postgresql://rag:rag@127.0.0.1:5432/rag

# Knowledge directory scanned by the backend. The desktop import flow copies user
# files into knowledge/imports/, and reindex will scan the whole knowledge tree.
# Synapse also writes a local incremental-index state file under this directory.
KNOWLEDGE_DIR=../../knowledge

# ------------------------------------------------------------------------------
# Embeddings
# ------------------------------------------------------------------------------
# Supported values:
# - hash   : built-in local deterministic embedding fallback
# - ollama : local Ollama embedding service
EMBEDDING_PROVIDER=ollama

# pgvector schema is currently kept at 64 dims. If the upstream embedding model
# returns a larger vector, Synapse will project it down to this size before write.
EMBEDDING_DIMENSIONS=64

# Local Ollama service settings.
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_EMBEDDING_MODEL=mxbai-embed-large:latest
EMBEDDING_TIMEOUT_SECONDS=60

# ------------------------------------------------------------------------------
# Retrieval thresholds
# ------------------------------------------------------------------------------
# Candidate pool before the final top_k cutoff.
RETRIEVAL_CANDIDATE_K=12

# A chunk is kept when ANY of the following thresholds is satisfied:
# - lexical score >= RETRIEVAL_MIN_LEXICAL_SCORE
# - vector score  >= RETRIEVAL_MIN_VECTOR_SCORE
# - fused score   >= RETRIEVAL_MIN_FUSED_SCORE
RETRIEVAL_MIN_LEXICAL_SCORE=0.08
RETRIEVAL_MIN_VECTOR_SCORE=0.42
RETRIEVAL_MIN_FUSED_SCORE=0.24

# ------------------------------------------------------------------------------
# LLM generation (OpenAI-compatible)
# ------------------------------------------------------------------------------
# Synapse calls: {LLM_BASE_URL}/chat/completions
# Fill all required fields and set LLM_ENABLED=true to enable real model output.
LLM_ENABLED=false
LLM_BASE_URL=https://api.openai.com/v1
LLM_API_KEY=
LLM_MODEL=
LLM_SUMMARY_MODEL=
LLM_TEMPERATURE=0.2
